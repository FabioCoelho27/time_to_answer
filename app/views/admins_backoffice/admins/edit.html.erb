<div class="row">
    <div class="col-lg-12">
         <h1 class="page-header">Editando</h1>
    </div>
    <!-- /.col-lg-12 -->
</div>
  <%= form_with(model: [ :admins_backoffice, @admin ], local: true) do |form| %>

    <div class="form-group">
        <%= form.label :email %>
        <%= form.text_field :email, class:"form-control",  placeholder:"Email do Administrador" %>
       
    </div>
      <div class="form-group">
        <%= form.label :password %>
        <%= form.text_field :password, class:"form-control",  placeholder:"Senha do Administrador" %>
      </div>
       <div class="form-group">
        <%= form.label :password_confirmation %>
        <%= form.text_field :password_confirmation, class:"form-control",  placeholder:"Confirmação da Senha do Administrador" %>
       <div class="row">
        <div class="col-lg-12">
          <h1 class="page-header"></h1>
      </div>
      <!-- /.col-lg-12 -->
    </div> 
      <button type="submit" class="btn btn-default">Salvar</button>
  <% end %>
</div>